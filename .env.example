# ═══════════════════════════════════════════════════════
# McAgent — Environment Configuration
# DeepSeek-V4: https://api-docs.deepseek.com/zh-cn/
# ═══════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────
# Get your API key: https://platform.deepseek.com/api-docs
DEEPSEEK_API_KEY=sk-your-key-here

# ── Model Selection ───────────────────────────────────
# deepseek-v4-flash  — Fast & economical (default)
# deepseek-v4-pro    — Maximum capability, slower
# Legacy (deprecated 2026/07/24): deepseek-chat, deepseek-reasoner
# DEEPSEEK_MODEL=deepseek-v4-flash

# ── Thinking Mode ─────────────────────────────────────
# DeepSeek-V4 thinks before answering for better accuracy.
# Disable for simple queries where raw speed matters.
# DEEPSEEK_THINKING_ENABLED=true

# ── Reasoning Effort ──────────────────────────────────
# high  — Default, suitable for general requests
# max   — Deepest reasoning, for complex agent/coding tasks
# DEEPSEEK_REASONING_EFFORT=high

# ── API Base URL ──────────────────────────────────────
# Default: https://api.deepseek.com (OpenAI-compatible)
# Beta:    https://api.deepseek.com/beta (strict mode tool calls)
# Anthropic-compatible: https://api.deepseek.com/anthropic
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Strict Mode (Beta) ────────────────────────────────
# When enabled, tool call output strictly follows JSON Schema.
# Requires base URL to be the beta endpoint.
# DEEPSEEK_STRICT_MODE=false

# ── Context Window ────────────────────────────────────
# DeepSeek-V4 supports up to 1M tokens.
# McAgent auto-evicts when approaching this limit.
# DEEPSEEK_MAX_TOKENS=524288   # 512K (balanced)
# DEEPSEEK_MAX_TOKENS=1048576  # 1M (full, uses more cache)

# ═══════════════════════════════════════════════════════
# Preset Profiles
# ═══════════════════════════════════════════════════════

# ── 🟢 Profile: low-cost (default) ────────────────────
# Best for daily use, quick answers, simple tasks
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_THINKING_ENABLED=true
# DEEPSEEK_REASONING_EFFORT=high
# DEEPSEEK_MAX_TOKENS=524288

# ── 🟡 Profile: balanced ─────────────────────────────
# Good quality, moderate speed, cost-efficient
# DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_THINKING_ENABLED=true
# DEEPSEEK_REASONING_EFFORT=high
# DEEPSEEK_MAX_TOKENS=524288

# ── 🔴 Profile: max-power ────────────────────────────
# Maximum capability for complex agent/coding tasks
# DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_THINKING_ENABLED=true
# DEEPSEEK_REASONING_EFFORT=max
# DEEPSEEK_MAX_TOKENS=1048576
# DEEPSEEK_STRICT_MODE=true
# DEEPSEEK_BASE_URL=https://api.deepseek.com/beta
